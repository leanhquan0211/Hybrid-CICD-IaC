upstream backend_pool {
    least_conn;
    {% for i in range(backend_count | default(2)) %}
    server backend-{{ i }}:80;
    {% endfor %}
}

server {
    listen 80;
    location / {
        proxy_pass http://backend_pool;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
